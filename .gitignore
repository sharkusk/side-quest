# Go build artifacts
/side-quest
/dist/
*.exe
*.test
*.out

# Go workspace / module cache local bits
/vendor/

# Editor / OS cruft
.DS_Store
*.swp
.idea/
.vscode/

# Local, un-shipped superfan voice pool (verbatim catch phrases; see spec §12)
superfan-lines.txt

# Local, per-user Claude Code settings and commands (not shared)
.claude/settings.local.json
.claude/commands/

# Dogfooding-only MCP registration (bare `side-quest` -> HEAD on PATH), written by
# `make dev`. Must NOT ship: the plugin registers via .claude-plugin/plugin.json, and
# a non-plugin user's own .mcp.json is written by `side-quest onboard`. Shipping this
# would give plugin installs a stray, PATH-resolved server that ENOENTs (SQ-0080).
/.mcp.json

# superpowers subagent-driven scratch (progress ledger; local, not shared)
.superpowers/

# side-quest-generated git hook shims (machine-local absolute paths; not shared).
# The tracked .githooks/pre-commit stays tracked; these four are install-time
# artifacts written by `side-quest install-hooks`.
/.githooks/prepare-commit-msg
/.githooks/commit-msg
/.githooks/post-commit
/.githooks/pre-push
