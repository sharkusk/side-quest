#!/bin/sh
# side-quest plugin launcher. Resolves the native `side-quest` binary for this
# OS/arch, provisioning it from the matching GitHub Release on first use.
# Resolution order (first hit wins):
#   1. a cached binary for this version
#   2. a side-quest already on PATH (dev build / `go install`)
#   3. download the matching release asset + verify its SHA-256
#   4. print an install hint and fail (never run something wrong)
set -eu

REPO="sharkusk/side-quest"

# We are a side-quest launcher: mark every binary we exec as plugin-launched, so
# detection stays reliable when we exec a dev build that lives on PATH outside the
# plugin tree (step 2) or when CLAUDE_PLUGIN_DATA has not propagated here (SQ-0072).
export SIDE_QUEST_PLUGIN=1

# Canonicalize our own path so the step-2 self-check compares absolute-to-absolute.
SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
SELF="$SELF_DIR/$(basename -- "$0")"
ROOT=$(CDPATH= cd -- "$SELF_DIR/.." && pwd -P)
VERSION=$(cat "$ROOT/VERSION" 2>/dev/null || echo dev)

# Under Claude Code's Bash tool on Windows the shell is Git Bash (MSYS), so a bare
# `side-quest` resolves to THIS POSIX script — but the download path below is built
# for a Unix release (uname os string, .tar.gz, an extensionless binary) and 404s on
# the windows_amd64.zip. Hand off to the sibling .cmd, which owns Windows provisioning
# (PowerShell unzip, side-quest.exe). cmd.exe runs it; `//c` stops MSYS mangling the
# /c switch, and cygpath gives cmd.exe a native path (SQ-0082).
case "$(uname -s 2>/dev/null)" in
MINGW* | MSYS* | CYGWIN*)
	exec cmd.exe //c "$(cygpath -w "$SELF_DIR/side-quest.cmd")" "$@"
	;;
esac

# The provisioned binary lives in the plugin's persistent data dir — the stable,
# documented location the terminal launcher also resolves (spec D2). CLAUDE_PLUGIN_DATA
# is exported only into Claude's own processes, so in a plain shell we reconstruct the
# same deterministic path; both launchers must agree or a binary provisioned by one is
# invisible to the other (SQ-0079).
DATA="${CLAUDE_PLUGIN_DATA:-$HOME/.claude/plugins/data/side-quest-side-quest}"
CACHE="$DATA/bin"
BIN="$CACHE/side-quest-$VERSION"

# sha256 of a file, portable across Linux (sha256sum) and macOS (shasum).
sha256() {
	if command -v sha256sum >/dev/null 2>&1; then
		sha256sum "$1" | awk '{print $1}'
	elif command -v shasum >/dev/null 2>&1; then
		shasum -a 256 "$1" | awk '{print $1}'
	else
		echo ""
	fi
}

# 1. Cached binary for this version.
if [ -x "$BIN" ]; then
	exec "$BIN" "$@"
fi

# 2. A real side-quest already on PATH, as long as it is not this launcher.
found=$(command -v side-quest 2>/dev/null || true)
if [ -n "$found" ]; then
	found_dir=$(CDPATH= cd -- "$(dirname -- "$found")" && pwd -P)
	found_abs="$found_dir/$(basename -- "$found")"
	if [ "$found_abs" != "$SELF" ] && [ -x "$found_abs" ]; then
		exec "$found_abs" "$@"
	fi
fi

# 3. Download the matching release asset and verify its checksum.
os=$(uname -s | tr '[:upper:]' '[:lower:]')
arch=$(uname -m)
case "$arch" in
	x86_64 | amd64) arch=amd64 ;;
	arm64 | aarch64) arch=arm64 ;;
esac
if [ "$VERSION" != dev ] && command -v curl >/dev/null 2>&1; then
	asset="side-quest_${VERSION}_${os}_${arch}.tar.gz"
	base="https://github.com/$REPO/releases/download/v$VERSION"
	tmp=$(mktemp -d)
	if curl -fsSL "$base/$asset" -o "$tmp/$asset" &&
		curl -fsSL "$base/checksums.txt" -o "$tmp/checksums.txt"; then
		want=$(grep " $asset\$" "$tmp/checksums.txt" | awk '{print $1}')
		got=$(sha256 "$tmp/$asset")
		if [ -n "$want" ] && [ "$want" = "$got" ]; then
			mkdir -p "$CACHE"
			tar -xzf "$tmp/$asset" -C "$tmp"
			mv "$tmp/side-quest" "$BIN"
			chmod +x "$BIN"
			rm -rf "$tmp"
			exec "$BIN" "$@"
		fi
	fi
	rm -rf "$tmp"
fi

# 4. Could not provision — tell the user how, and fail.
echo "side-quest: could not locate or download the side-quest binary." >&2
echo "  Install it with:  go install github.com/$REPO/cmd/side-quest@latest" >&2
echo "  (then ensure ~/go/bin is on your PATH), or download a release from" >&2
echo "  https://github.com/$REPO/releases and put it on your PATH." >&2
exit 1
