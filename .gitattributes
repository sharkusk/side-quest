# Markdown is embedded into the binary and shipped to MCP clients verbatim
# (core.md/agents.md/plugin.md, SKILL.md). Force LF so the byte budget stays
# deterministic across platforms — Windows autocrlf would otherwise add one byte
# per line and push Core over its 1200-byte limit — and so clients never receive
# CRLF (SQ-0106).
*.md text eol=lf

internal/cli/launcher.cmd text eol=crlf

# The POSIX launcher is embedded into the binary and written verbatim onto the
# user's PATH; a CRLF checkout (Windows autocrlf) would embed "#!/bin/sh\r" —
# "bad interpreter" on macOS/Linux — and make LF- and CRLF-built binaries
# perpetually rewrite each other's installed launcher via Refresh (SQ-0122).
internal/cli/launcher.sh text eol=lf
